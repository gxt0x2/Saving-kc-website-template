---
import NeighborhoodPageTemplate from '@/components/NeighborhoodPageTemplate.astro';
import { getCountiesByState } from '@/data/counties';

export function getStaticPaths() {
  return getCountiesByState('mo').flatMap((county) =>
    county.cities.flatMap((city) =>
      city.neighborhoods.map((n) => ({
        params: { county: county.slug, city: city.slug, neighborhood: n.slug },
        props: { neighborhood: n, city, county },
      }))
    )
  );
}

const { neighborhood, city, county } = Astro.props;

const breadcrumbs = [
  { label: 'Missouri', href: '/mo/' },
  { label: `${county.name}`, href: `/mo/${county.slug}/` },
  { label: city.name, href: `/mo/${county.slug}/${city.slug}/` },
  { label: neighborhood.name },
];
---

<NeighborhoodPageTemplate
  neighborhood={neighborhood}
  city={city}
  county={county}
  breadcrumbs={breadcrumbs}
/>
